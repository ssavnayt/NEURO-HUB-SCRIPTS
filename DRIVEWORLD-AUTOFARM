    local mouse = Players.LocalPlayer:GetMouse()
    local input = {Position = Vector3.new(mouse.X, mouse.Y, 0)} -- Эмуляция input объекта
    updateSlider(input)
end)

UserInputService.InputChanged:Connect(function(input)
