-- === ЛОГИКА ЦВЕТОВ ===
local function isBlue(c)
    if not c then return false end
    return math.abs(c.R*255 - TARGET_BLUE.R*255) <= TOLERANCE and 
           math.abs(c.G*255 - TARGET_BLUE.G*255) <= TOLERANCE and 
           math.abs(c.B*255 - TARGET_BLUE.B*255) <= TOLERANCE
end

local function isGreen(c)
    if not c then return false end
    if c.G * 255 > 200 and c.R * 255 < 100 then return true end
    return math.abs(c.R*255 - TARGET_GREEN.R*255) <= TOLERANCE and 
           math.abs(c.G*255 - TARGET_GREEN.G*255) <= TOLERANCE and 
           math.abs(c.B*255 - TARGET_GREEN.B*255) <= TOLERANCE
end

-- === УПРАВЛЕНИЕ NOCLIP ===
local function toggleNoclip(state)
    if state then
        -- Включаем ноуклип (каждый кадр)
        noclipConnection = RunService.Stepped:Connect(function()
            -- Ноуклип для машины
            if currentCar then
                for _, part in pairs(currentCar:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
            -- Ноуклип для игрока
            local char = Players.LocalPlayer.Character
            if char then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end)
    else
        -- Выключаем ноуклип и ВОЗВРАЩАЕМ коллизию
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
        
        -- Возвращаем физику машине
        if currentCar then
            for _, part in pairs(currentCar:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
        end
        -- Возвращаем физику игроку
        local char = Players.LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = true end
            end
        end
    end
end

-- === ЛОГИКА ПОЛЕТА ===
local function flyTo(car, targetPart)
    local root = car.PrimaryPart or car:FindFirstChild("Body") or car:FindFirstChildWhichIsA("BasePart")
    if not root then return end

    local targetPos = targetPart.Position + Vector3.new(0, currentHeight, 0)
    local direction = (targetPos - root.Position)
    
    if direction.Magnitude > 5 then
        root.AssemblyLinearVelocity = direction.Unit * FLY_SPEED
        local lookAtPos = Vector3.new(targetPart.Position.X, root.Position.Y, targetPart.Position.Z)
        root.CFrame = CFrame.lookAt(root.Position, lookAtPos)
    else
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        currentHeight = DEFAULT_HEIGHT 
    end
end

-- === ПОИСК ЧЕКПОИНТА ===
local function findBestCheckpoint()
    local blueTarget = nil
    local greenTarget = nil

    for _, race in pairs(workspace.Races:GetChildren()) do
        local cpFolder = race:FindFirstChild("Checkpoints")
        if cpFolder then
            for _, cp in pairs(cpFolder:GetChildren()) do
                local inner = cp:FindFirstChild("Inner")
                if inner then
                    local b = inner:FindFirstChild("Base")
                    local e = inner:FindFirstChild("Expand")
                    local function getCol(o) return (o:IsA("Part") or o:IsA("MeshPart")) and o.Color or o.Color3 end
                    
                    local colorB = b and getCol(b)
                    local colorE = e and getCol(e)

                    if isBlue(colorB) or isBlue(colorE) then
                        blueTarget = inner
                        break 
                    end
                    if not greenTarget and (isGreen(colorB) or isGreen(colorE)) then
                        greenTarget = inner
                    end
                end
            end
        end
        if blueTarget then break end
    end
    return blueTarget or greenTarget
end

-- === ГЛАВНЫЙ ЦИКЛ ГОНКИ ===
local function startLoop()
    while _G.AutoRaceEnabled do
        task.wait()
        
        local myCar = nil
        for _, car in pairs(workspace.Cars:GetChildren()) do
            local d = car:FindFirstChild("CurrentDriver")
            if d and (d.Value == Players.LocalPlayer.Name or d.Value == Players.LocalPlayer or (d:IsA("ObjectValue") and d.Value == Players.LocalPlayer.Character)) then
                myCar = car
                break
            end
        end

        currentCar = myCar

        if myCar then
            local target = findBestCheckpoint()
            
            if target then
                if target ~= lastTarget then
                    lastTarget = target
                    targetStartTime = tick()
                    currentHeight = DEFAULT_HEIGHT 
                else
                    if tick() - targetStartTime > 10 then
                        if currentHeight ~= STUCK_HEIGHT then
                            currentHeight = STUCK_HEIGHT
                        end
                    end
                end
                
                flyTo(myCar, target)
            end
        end
    end
    -- При выходе из цикла сбрасываем всё
    toggleNoclip(false)
    currentCar = nil
end

