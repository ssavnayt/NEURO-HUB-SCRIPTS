        if ScreenGui then ScreenGui.Enabled = not ScreenGui.Enabled end
        return
    end

    if gameProcessed then return end 

    local keyCode = input.KeyCode

    -- SmartRace бинды
    if Binds.FastStop.Enabled and keyCode == Binds.FastStop.Key then
