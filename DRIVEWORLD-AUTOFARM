-- --- ЛОГИКА СЛАЙДЕРА ---
local function updateSlider(input)
    local sliderX = SliderBar.AbsolutePosition.X
    local sliderWidth = SliderBar.AbsoluteSize.X
    local inputX = input.Position.X
    
    -- Вычисляем процент заполнения (0..1)
    local percent = math.clamp((inputX - sliderX) / sliderWidth, 0, 1)
    
    -- Вычисляем скорость
    local newSpeed = math.floor(MIN_SPEED + (MAX_SPEED - MIN_SPEED) * percent)
    
    -- Применяем
    FLY_SPEED = newSpeed
    SpeedLabel.Text = "SPEED: " .. newSpeed
    SliderFill.Size = UDim2.new(percent, 0, 1, 0)
end

-- Инициализация начальной позиции ползунка
local startPercent = (FLY_SPEED - MIN_SPEED) / (MAX_SPEED - MIN_SPEED)
SliderFill.Size = UDim2.new(startPercent, 0, 1, 0)

