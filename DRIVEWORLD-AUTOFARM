-- Настройки
_G.AutoRaceEnabled = false
local FLY_SPEED = 300 
local HEIGHT_OFFSET = 15
local TARGET_BLUE = Color3.fromRGB(55, 155, 255)
local TARGET_GREEN = Color3.fromRGB(55, 400, 0)
local TOLERANCE = 25

