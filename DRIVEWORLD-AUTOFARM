    if exclude ~= "AutoFly" then
        _G.AutoFlyEnabled = false
        AutoFlyButton.Text = "AUTO FLY: OFF"
        AutoFlyButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    end
end

